APP_NAME="Q-Less"
APP_ENV=production
APP_KEY=base64:ubZ6M1E5xvPOHBAj3YS3uTxh6FkQlFwbTm9MVL/8N+4=
APP_DEBUG=false
APP_URL=https://domain-kamu.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=BEQLES
DB_USERNAME=root
DB_PASSWORD=ISI_PASSWORD_DB_PRODUCTION

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=ISI_SMTP_HOST
MAIL_PORT=587
MAIL_USERNAME=ISI_EMAIL
MAIL_PASSWORD=ISI_PASSWORD_EMAIL
MAIL_FROM_ADDRESS="noreply@domain-kamu.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Firebase Admin SDK — sesuaikan path absolut di server Linux
FIREBASE_CREDENTIALS=/var/www/html/Backend/storage/app/firebase-service-account.json
